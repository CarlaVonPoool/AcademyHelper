# Anthropic API Key for Claude
ANTHROPIC_API_KEY=sk-ant-api03-your-real-key-here

# App Password Protection
APP_PASSWORD=dein-sicheres-passwort-hier

# Admin Password für Analytics Dashboard  
ADMIN_PASSWORD=your-admin-password-here

# Default documents directory (optional)
# For local development, adjust to your Academy folder path:
DOCS_DIR=~/Documents/Academy
# For production/others, use: ./documents

# N8N Webhook für Feedback Logging
N8N_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/your-webhook-id-here

# N8N API Key für zusätzliche Sicherheit (optional)
N8N_API_KEY=your-secret-api-key-for-n8n