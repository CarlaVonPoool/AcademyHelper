# Streamlit Secrets Template
# Copy this to secrets.toml and add your real values
# secrets.toml is automatically ignored by git

ANTHROPIC_API_KEY = "sk-ant-api03-your-real-key-here"

# App Password Protection
APP_PASSWORD = "dein-sicheres-passwort-hier"

# Admin Passwort für Analytics
ADMIN_PASSWORD = "dein-admin-passwort-hier"

# Optional: Default documents directory
# For local development (adjust to your path):
DOCS_DIR = "~/Documents/Academy"
# For production/others:
# DOCS_DIR = "./documents"

# N8N Webhook URL für Feedback Logging
N8N_WEBHOOK_URL = "https://your-n8n-instance.app.n8n.cloud/webhook/your-webhook-id-here"

# N8N API Key für Verschlüsselung (optional)
N8N_API_KEY = "dein-geheimer-n8n-schlüssel"